{
    "name": "NewsJS",
    "version": "1.0.0",
    "description": "News portal with TypeScript",
    "main": "webpack.config.js",
    "scripts": {
        "start": "webpack serve --open --config ./webpack.config.js --env mode=dev",
        "build": "webpack --config ./webpack.config.js --env mode=prod",
